lm.BARI.Weight.B.PreWL <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + MaxPercentWeightLossPostSurgery_computed + PctWL_postsurgery_Over20, data = BARISTEP_database_B)
plot(lm.BARI.Weight.B.PreWL)
summary(lm.BARI.Weight.B.PreWL)

