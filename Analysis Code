#GLP1 change B only
lm.BARI.Weight.1.GLP1.B <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + GLP1_baselinechange, data = BARISTEP_database_B)
plot(lm.BARI.Weight.1.GLP1.B)
summary(lm.BARI.Weight.1.GLP1.B)

#Baseline diabetes status (diabetes vs. no diabetes/pre-diabetes) on %WL induced by Semaglutide 2.4mg. 
lm.BARI.PctWL.ITT.exploratory <- lm(PctWL_week68 ~ Treatment_allocation + TypeOfSurgery + Diabetes*Treatment_allocation + Sex + v2Weightkg, data = BARISTEP_database_ITT)
summary(lm.BARI.PctWL.ITT.exploratory)
lsmeans(lm.BARI.PctWL.ITT.exploratory, pairwise~ Diabetes|Treatment_allocation, ddf="Satterthwaite",adjust = "none")
confint(lsmeans(lm.BARI.PctWL.ITT.exploratory, pairwise~Diabetes|Treatment_allocation, ddf="Satterthwaite",adjust = "none"))

lm.BARI.PctWL.ITT.exploratory.B <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg, data = BARISTEP_database_B)
plot(lm.BARI.PctWL.ITT.exploratory.B)
summary(lm.BARI.PctWL.ITT.exploratory.B)
lsmeans(lm.BARI.PctWL.ITT.exploratory.B, pairwise~ Diabetes, ddf="Satterthwaite",adjust = "none")
confint(lsmeans(lm.BARI.PctWL.ITT.exploratory.B, pairwise~Diabetes, ddf="Satterthwaite",adjust = "none"))

#PR/WR predict %WL
BARISTEP_database_B %>% 
  ggplot(mapping = aes(x = as.factor(PctWL_postsurgery_Over20), y = PctWL_week68)) +
  geom_boxplot()
ggplot(BARISTEP_database_B, aes(x=PctWL_week68))+
  geom_histogram(color="black", fill="white", bins = 8)+
  facet_grid(as.factor(PctWL_postsurgery_Over20) ~ .)

crosstable(BARISTEP_database_B, c(PctWL_week68), by =PctWL_postsurgery_Over20, total="both", percent_pattern="{n} ({p_col})", percent_digits=1)

lm.BARI.Weight.B.WRPR <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + PctWL_postsurgery_Over20, data = BARISTEP_database_B)
plot(lm.BARI.Weight.B.WRPR)
summary(lm.BARI.Weight.B.WRPR)
lsmeans(lm.BARI.Weight.B.WRPR, pairwise~ as.factor(PctWL_postsurgery_Over20), ddf="Satterthwaite",adjust = "none")
confint(lsmeans(lm.BARI.Weight.B.WRPR, pairwise~as.factor(PctWL_postsurgery_Over20), ddf="Satterthwaite",adjust = "none"))

BARISTEP_database_B %>%
  ggplot(mapping = aes(x = MaxPercentWeightLossPostSurgery_computed, y = PctWL_week68)) +
