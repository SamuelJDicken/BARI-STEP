#Compute Change Outcomes
BARISTEP_database$PctWL_V6 <- ((BARISTEP_database$v2Weightkg - BARISTEP_database$V6WeightKG)/BARISTEP_database$v2Weightkg) *100
BARISTEP_database$PctWL_V10 <- ((BARISTEP_database$v2Weightkg - BARISTEP_database$V10WeightKG)/BARISTEP_database$v2Weightkg) *100
BARISTEP_database$PctWL_V15 <- ((BARISTEP_database$v2Weightkg - BARISTEP_database$v15WeightKG)/BARISTEP_database$v2Weightkg) *100
BARISTEP_database$PctWL_V20 <- ((BARISTEP_database$v2Weightkg - BARISTEP_database$v20Weightkg)/BARISTEP_database$v2Weightkg) *100
BARISTEP_database$PctWL_V24 <- ((BARISTEP_database$v2Weightkg - BARISTEP_database$v24WeightKG)/BARISTEP_database$v2Weightkg) *100

BARISTEP_database_long <- pivot_longer(BARISTEP_database, cols=c('PctWL_V6','PctWL_V10','PctWL_V15','PctWL_V20','PctWL_V24'), 
                                       names_to = "visit", values_to = "PctWL")
View(BARISTEP_database_long)

BARISTEP_database_long$visit_numeric <- 0
BARISTEP_database_long$visit_numeric[BARISTEP_database_long$visit == "PctWL_V6"] <- 2
BARISTEP_database_long$visit_numeric[BARISTEP_database_long$visit == "PctWL_V10"] <- 3
BARISTEP_database_long$visit_numeric[BARISTEP_database_long$visit == "PctWL_V15"] <- 4
BARISTEP_database_long$visit_numeric[BARISTEP_database_long$visit == "PctWL_V20"] <- 5
BARISTEP_database_long$visit_numeric[BARISTEP_database_long$visit == "PctWL_V24"] <- 6
tab1(BARISTEP_database_long$visit_numeric)

PctWL_RepeatedMeasures <- lmer(PctWL ~Treatment_allocation*factor(visit_numeric) + Treatment_allocation + TypeOfSurgery + Diabetes + Sex + v2Weightkg +
                                 (1|identifier), data = BARISTEP_database_long)
summary(PctWL_RepeatedMeasures)
plot_model(PctWL_RepeatedMeasures, type='diag')
lsmeans(PctWL_RepeatedMeasures, pairwise~Treatment_allocation|visit_numeric, ddf="Satterthwaite",adjust = "none")
