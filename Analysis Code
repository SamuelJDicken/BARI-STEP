BARISTEP_database$PctWL_week68 <- ((BARISTEP_database$v2Weightkg - BARISTEP_database$v24WeightKG)/BARISTEP_database$v2Weightkg) *100

BARISTEP_database %>% 
  ggplot(mapping = aes(x = Treatment_allocation, y = PctWL_week68)) +
  geom_boxplot()
BARISTEP_database %>%
  ggplot(mapping = aes(x = PctWL_week68)) +
  geom_histogram(bins = 10)
ggplot(BARISTEP_database, aes(x=PctWL_week68))+
  geom_histogram(color="black", fill="white", bins = 8)+
  facet_grid(Treatment_allocation ~ .)

summary(BARISTEP_database$PctWL_week68)
crosstable(BARISTEP_database, c(PctWL_week68), by =Treatment_allocation, total="both", percent_pattern="{n} ({p_col})", percent_digits=1, funs_arg=list(dig=2))

BARISTEP_database$ITT <- 0
BARISTEP_database$ITT[!is.na(BARISTEP_database$PctWL_week68)] <- 1
tab1(BARISTEP_database$ITT)
BARISTEP_database_ITT <- BARISTEP_database %>%
  filter(ITT == 1)
View(BARISTEP_database_ITT)

lm.BARI.Weight.1 <- lm(PctWL_week68 ~ Treatment_allocation + TypeOfSurgery + Diabetes + Sex + v2Weightkg, data = BARISTEP_database_ITT)
plot(lm.BARI.Weight.1)
summary(lm.BARI.Weight.1)
lsmeans(lm.BARI.Weight.1, pairwise~Treatment_allocation, ddf="Satterthwaite",adjust = "none")
confint(lsmeans(lm.BARI.Weight.1, pairwise~Treatment_allocation, ddf="Satterthwaite",adjust = "none"))


