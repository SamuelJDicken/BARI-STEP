#Predictors of %WL 

#%WL did not significantly differ with age, ethnicity, diabetes status, sex or type of surgery.
#B only
BARISTEP_database_B <- BARISTEP_database %>%
  filter(Treatment_allocation == "B")
View(BARISTEP_database_B)

#ScreeningAge, Ethnicity_coded, months_since_surgery, GLP1_baselinechange
BARISTEP_database %>% 
  ggplot(mapping = aes(x = GLP1_baselinechange, y = PctWL_week68, group = as.factor(Treatment_allocation), colour =  as.factor(Treatment_allocation))) +
  geom_smooth() +
  geom_point()

BARISTEP_database_B %>% 
  ggplot(mapping = aes(x = ScreeningAge, y = PctWL_week68, group = as.factor(Treatment_allocation), colour =  as.factor(Treatment_allocation))) +
  geom_smooth() +
  geom_point()
BARISTEP_database_B %>% 
  ggplot(mapping = aes(x = Ethnicity_coded, y = PctWL_week68)) +
  geom_boxplot()
crosstable(BARISTEP_database_B, c(PctWL_week68), by =Ethnicity_coded, total="both", percent_pattern="{n} ({p_col})", percent_digits=1)
BARISTEP_database_B %>% 
  ggplot(mapping = aes(x = months_since_surgery, y = PctWL_week68, group = as.factor(Treatment_allocation), colour =  as.factor(Treatment_allocation))) +
  geom_smooth() +
  geom_point()
BARISTEP_database_B %>% 
  ggplot(mapping = aes(x = GLP1_baselinechange, y = PctWL_week68, group = as.factor(Treatment_allocation), colour =  as.factor(Treatment_allocation))) +
  geom_smooth() +
  geom_point()

lm.BARI.Weight.B <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + ScreeningAge + as.factor(Ethnicity_coded) + months_since_surgery + GLP1_baselinechange, data = BARISTEP_database_B)
plot(lm.BARI.Weight.B)
summary(lm.BARI.Weight.B)

#ScreeningAge
lm.BARI.Weight.B <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + ScreeningAge, data = BARISTEP_database_B)
plot(lm.BARI.Weight.B)
summary(lm.BARI.Weight.B)

#Ethnicity_coded
lm.BARI.Weight.B <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + as.factor(Ethnicity_coded), data = BARISTEP_database_B)
plot(lm.BARI.Weight.B)
summary(lm.BARI.Weight.B)

#months_since_surgery
lm.BARI.Weight.B <- lm(PctWL_week68 ~ TypeOfSurgery + Diabetes + Sex + v2Weightkg + months_since_surgery, data = BARISTEP_database_B)
plot(lm.BARI.Weight.B)
